{
  "name": "httptoolkit-mcp",
  "version": "0.1.0",
  "description": "MCP server for intercepting, mocking and reverse-engineering HTTP(S) traffic via Mockttp, with adb automation for Android emulators",
  "type": "module",
  "bin": {
    "httptoolkit-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepare": "tsc",
    "test": "node test/smoke.mjs && node test/ws-smoke.mjs && node test/protobuf-smoke.mjs && node test/classify-smoke.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "http",
    "proxy",
    "mockttp",
    "mitm",
    "protobuf",
    "grpc",
    "android",
    "adb",
    "reverse-engineering"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "mockttp": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
